# Backend API URL (used by next.config.mjs rewrites — do NOT include /api suffix)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (Railway) example:
# NEXT_PUBLIC_API_URL=https://hna-acadex-backend-production-df16.up.railway.app

# Optional: Production site origin (used for SSR URL resolution)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
